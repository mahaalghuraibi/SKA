# ── Roboflow (optional / legacy for dish AI) ───────────────────────────────
ROBOFLOW_API_KEY=
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_MODEL_ID=
ROBOFLOW_FOOD_TYPES_URL=

# Optional dish vision (unused by current Gemini flow)
# OPENAI_API_KEY=

# ── Gemini Vision (primary) ─────────────────────────────────────────────────
# Shared key used by both dish + monitoring unless dedicated keys are set below.
# Create at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Dedicated key for dish AI (optional; falls back to GEMINI_API_KEY)
DISH_GEMINI_API_KEY=
# Dedicated key for monitoring AI (optional; falls back to GEMINI_API_KEY)
MONITORING_GEMINI_API_KEY=

# Shared model fallback
GEMINI_VISION_MODEL=gemini-2.0-flash

# Dedicated model overrides (optional)
DISH_GEMINI_MODEL=gemini-2.0-flash
MONITORING_GEMINI_MODEL=gemini-2.0-flash

# Monitoring demo mode: true/1/yes/on => static demo results (no Gemini calls)
MONITORING_AI_DEMO_MODE=false

# ── YOLO monitoring (PPE + hygiene / trash scene checks) ───────────────────
# Primary weights (required): PPE + hygiene; classes mapped to trash/bins go to hygiene alerts.
# YOLO_MODEL_PATH=/absolute/path/to/keremberk_ppe.pt
#
# Standard COCO person detector (workers localization only). Not used by dish/Gemini flows.
# Default: ml/models/yolov8n.pt if that file exists; otherwise Ultralytics downloads yolov8n.pt on first use.
# PERSON_MODEL_PATH=/absolute/path/to/yolov8n.pt
# PERSON_MODEL_PATH=yolov8s.pt
#
# Optional dedicated hygiene weights (floor litter, bins, etc.)
# YOLO_WASTE_MODEL_PATH=/absolute/path/to/waste_yolov8.pt

# Production AI mode: stricter image checks and review handling
PRODUCTION_AI_MODE=false

# ── API / deployment & security ─────────────────────────────────────────────
# development | production (production: strict JWT secret, no dev auth bypass, no OpenAPI UI)
# ENVIRONMENT=development
#
# Required in production: long random string (≥32 chars). Used to sign JWT access tokens.
# SECRET_KEY=
#
# Comma-separated allowed browser origins. In production, must be set or CORS will block browsers.
# CORS_ALLOW_ORIGINS=https://your-app.example.com,https://www.your-app.example.com
#
# Optional: restrict Host header (behind a reverse proxy, list your public hostname(s)).
# ALLOWED_HOSTS=your-app.example.com,www.your-app.example.com
#
# HSTS: only if the API is served only over HTTPS (terminates TLS on this service or trust chain).
# ENABLE_HSTS=false
# HSTS_MAX_AGE=63072000
#
# Never set in production. When true, first DB user is used if token is missing (dev only).
# DEV_AUTH_BYPASS=false
#
# Access token lifetime (minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
#
# Maximum image bytes for POST /api/v1/monitoring/analyze-frame (default 8 MiB)
# MONITORING_UPLOAD_MAX_BYTES=8388608

# ── Camera stream URLs (supervisor API) ─────────────────────────────────────
# stream_url values are stored as provided; API responses redact rtsp:// user:pass.
# For production, prefer vault/KMS or app-level encryption at rest for credentials.
