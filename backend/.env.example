# ── Roboflow (optional / legacy for dish AI) ───────────────────────────────
ROBOFLOW_API_KEY=
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_MODEL_ID=
ROBOFLOW_FOOD_TYPES_URL=

# Optional dish vision (unused by current Gemini flow)
# OPENAI_API_KEY=

# ── Gemini Vision (primary) ─────────────────────────────────────────────────
# Shared key used by both dish + monitoring unless dedicated keys are set below.
# Create at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Dedicated key for dish AI (optional; falls back to GEMINI_API_KEY)
DISH_GEMINI_API_KEY=
# Dedicated key for monitoring AI (optional; falls back to GEMINI_API_KEY)
MONITORING_GEMINI_API_KEY=

# Shared model fallback
GEMINI_VISION_MODEL=gemini-2.0-flash

# Dedicated model overrides (optional)
DISH_GEMINI_MODEL=gemini-2.0-flash
MONITORING_GEMINI_MODEL=gemini-2.0-flash

# Monitoring demo mode: true/1/yes/on => static demo results (no Gemini calls)
MONITORING_AI_DEMO_MODE=false

# Production AI mode: stricter image checks and review handling
PRODUCTION_AI_MODE=false
